      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Unit Information|key=Other Requirements}}</default>
    </data>
    <data source="shield_damage">
      <label>Shield Damage</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Shield Damage}}</default>
    </data>
    <data source="armor_piercing">
      <label>Armor Piercing</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Armor Piercing}}</default>
    </data>
    <data source="energy_drain">
      <label>Energy Drain</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Energy Drain}}</default>
    </data>
    <data source="damage_radius">
      <label>Damage Radius</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Damage Radius}}</default>
    </data>
    <data source="accuracy">
      <label>Accuracy</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Accuracy}}</default>
