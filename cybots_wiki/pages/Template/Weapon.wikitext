    <data source="shots_per_turn">
      <label>Shots Per Turn</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Shots Per Turn}}</default>
    </data>
    <data source="energy_per_shot">
      <label>Energy Per Shot</label>
      <default>{{#invoke:Weapons|get|{{PAGENAME}}|section=Properties|key=Energy Per Shot}}</default>
    </data>
    <data source="max_targets_per_turn">
