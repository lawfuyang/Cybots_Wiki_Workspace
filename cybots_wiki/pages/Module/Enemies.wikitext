-- ── Load enemy data ──────────────────────────────────────────────────────────
local ok, DATA = pcall(function() return mw.loadData('Module:Enemies/data') end)
if not ok or type(DATA) ~= 'table' then
    ok, DATA = pcall(function() return mw.loadData('Module:Enemies_data') end)
end
if not ok or type(DATA) ~= 'table' then DATA = nil end

-- ── Load equipment data modules for image lookups ────────────────────────────
local function loadMod(primary, fallback)
    local ok2, d = pcall(function() return mw.loadData(primary) end)
    if ok2 and type(d) == 'table' then return d end
    if fallback then
        ok2, d = pcall(function() return mw.loadData(fallback) end)
        if ok2 and type(d) == 'table' then return d end
    end
    return nil
end

local CHASSIS_DATA  = loadMod('Module:Chassis/data',  'Module:Chassis_data')

-- ── Build title → image1 lookup from an array-style data module ──────────────
local function buildImageMap(dataModule)
    local map = {}
    if not dataModule then return map end
    for _, entry in pairs(dataModule) do
        if type(entry) == 'table' and entry.title and entry.image1 then
            map[entry.title] = entry.image1
            map[entry.title:lower()] = entry.image1
        end
    end
    return map
end

local CHASSIS_IMG = buildImageMap(CHASSIS_DATA)

-- ── Image lookup helpers ──────────────────────────────────────────────────────
-- Try exact title, then lowercase, then common shield alias variants
local function lookupImage(map, name)
    if not name then return nil end
    if map[name] then return map[name] end
    local lower = name:lower()
    if map[lower] then return map[lower] end
    -- Shield alias: "Baron" → "Baron (Shield)"
    local withShield = name .. ' (Shield)'
    if map[withShield] then return map[withShield] end
    if map[withShield:lower()] then return map[withShield:lower()] end
    return nil
end

-- ── Build a Fandom wiki URL from an item name ──────────────────────────────
local BASE_URL = 'https://cybots.fandom.com/wiki/'
local function makeWikiUrl(name)
    if not name or name == '' then return '' end
    return BASE_URL .. name:gsub(' ', '_')
end

-- ── Render one equipment item as a plain external text link ──────────────────
local function fmtItem(item)
    if not item then return '—' end
    local name = item.name or ''
    if name == '' then return name end
    return '[' .. makeWikiUrl(name) .. ' ' .. name .. ']'
end

-- ── Safe list length (works on mw.loadData frozen tables) ────────────────────
local function listLen(t)
    if not t then return 0 end
    local n = 0
    for _ in ipairs(t) do n = n + 1 end
    return n
end

-- ── Format a list of equipment items, deduplicating with ×N ────────────────
local function fmtList(list)
    if not list or listLen(list) == 0 then return '—' end
    -- Deduplicate while preserving order
    local seen  = {}
    local order = {}
    for _, item in ipairs(list) do
        local key = item.name or tostring(item)
        if seen[key] then
            seen[key].count = seen[key].count + 1
        else
            seen[key] = { item = item, count = 1 }
            table.insert(order, key)
        end
    end
    local parts = {}
    for _, key in ipairs(order) do
        local e = seen[key]
        local rendered = fmtItem(e.item)
        if e.count > 1 then
            rendered = rendered .. ' <small>×' .. e.count .. '</small>'
        end
        table.insert(parts, rendered)
    end
    return table.concat(parts, '<br/>')
end

-- ── Chassis image column: look up from Chassis_data, fall back to guessing ───
local function chassisImageCell(chassis)
    if not chassis or not chassis.name then return '—' end
    local img = lookupImage(CHASSIS_IMG, chassis.name)
    local url = makeWikiUrl(chassis.name)
    if img and img ~= '' then
        if url ~= '' then
            return '[' .. url .. ' [[File:' .. img .. '|60px|link=]]]'
        end
        return '[[File:' .. img .. '|60px]]'
    end
    -- Fallback: guess filename from chassis name
    local guess = chassis.name:gsub(' ', '_') .. '.png'
    if url ~= '' then
        return '[' .. url .. ' [[File:' .. guess .. '|60px|link=]]]'
    end
    return '[[File:' .. guess .. '|60px]]'
end

