local p = {}
local helper = require('Module:DataTableHelper')

local ok, DATA = pcall(function() return mw.loadData('Module:Modules/data') end)
if not ok or type(DATA) ~= 'table' then DATA = nil end

function p.get(frame)
    local args = (frame and frame.args) or {}
    local name = args[1] or args.name or args.title or args.module
    if not name and args.url then name = helper.title_from_url(args.url) end
    if not name then return '' end
    local entry = helper.findEntry(name, DATA or {})
    if not entry then return '' end
    local prop = args.prop or args.field or args.p or args[2]
    if prop and (prop == 'image' or prop == 'image1' or prop == 'file') then
        local filename = entry.image1 or entry.image
        if not filename then return '' end
        if args.raw then return tostring(filename) end
        local size = args.size or args.imageSize or '60px'
        return '[[File:' .. tostring(filename) .. '|' .. tostring(size) .. ']]'
    end
    if prop and entry[prop] ~= nil then return helper.fmt(entry[prop]) end
    local section = args.section or args.s
    local key = args.key or args.k
    if section and entry.sections and type(entry.sections) == 'table' and entry.sections[section] then
        if key then return helper.fmt(entry.sections[section][key]) end
        return helper.fmt(entry.sections[section])
    end
    return entry.title or ''
end

function p.generateTable(frame)
    local data = DATA or helper.loadData('Module:Modules/data', 'Module:Modules_data')

    local cols = {
        { title = 'Image', section = nil, key = 'image' },
        { title = 'Name', section = nil, key = 'name' },
        { title = 'Module Type', section = 'Unit Information', key = 'Module Type' },
        { title = 'Cost', section = 'Unit Information', key = 'Cost' },
        { title = 'Other Requirements', section = 'Unit Information', key = 'Other Requirements' },
        { title = 'Weight', section = 'Properties', key = 'Weight' },
        { title = 'Required Tech Level', section = 'Properties', key = 'Required Tech Level' },
        { title = 'Energy Use', section = 'Properties', key = 'Energy Use' },
        { title = 'Speed', section = 'Properties', key = 'Speed' },
        { title = 'Critical Hit Chance', section = 'Properties', key = 'Critical Hit Chance' },
        { title = 'Accuracy', section = 'Properties', key = 'Accuracy' },
        { title = 'Firing Rate', section = 'Properties', key = 'Firing Rate' },
        { title = 'Shield Deflection', section = 'Properties', key = 'Shield Deflection' },
        { title = 'Armor Deflection', section = 'Properties', key = 'Armor Deflection' },
        { title = 'Energy Efficiency', section = 'Properties', key = 'Energy Efficiency' },
        { title = 'Energy Drain Deflection', section = 'Properties', key = 'Energy Drain Deflection' },
        { title = 'Bounty Enhanced', section = 'Properties', key = 'Bounty Enhanced' },
        { title = 'Experience Enhanced', section = 'Properties', key = 'Experience Enhanced' },
        { title = 'Defensive Merit', section = 'Properties', key = 'Defensive Merit' },
    }

    return helper.generateTable(data, 'Module', cols, 'Could not load data module. Check Module:Modules/data or Module:Modules_data exists.')
end

return p