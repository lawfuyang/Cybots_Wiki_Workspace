local p = {}
local helper = require('Module:DataTableHelper')

local ok, DATA = pcall(function() return mw.loadData('Module:Reactors/data') end)
if not ok or type(DATA) ~= 'table' then DATA = nil end

function p.get(frame)
    local args = (frame and frame.args) or {}
    local name = args[1] or args.name or args.title or args.reactor
    if not name and args.url then name = helper.title_from_url(args.url) end
    if not name then return '' end
    local entry = helper.findEntry(name, DATA or {})
    if not entry then return '' end
    local prop = args.prop or args.field or args.p or args[2]
    if prop and (prop == 'image' or prop == 'image1' or prop == 'file') then
        local filename = entry.image1 or entry.image
        if not filename then return '' end
        local size = args.size or args.imageSize or '60px'
        return '[[File:' .. tostring(filename) .. '|' .. tostring(size) .. ']]'
    end
    if prop and entry[prop] ~= nil then return helper.fmt(entry[prop]) end
    local section = args.section or args.s
    local key = args.key or args.k
    if section and entry.sections and type(entry.sections) == 'table' and entry.sections[section] then
        if key then return helper.fmt(entry.sections[section][key]) end
        return helper.fmt(entry.sections[section])
    end
    return entry.title or ''
end

function p.generateTable(frame)
    local data = DATA or helper.loadData('Module:Reactors/data', 'Module:Reactors_data')
    
    local cols = {
        { title = 'Image', section = nil, key = 'image' },
        { title = 'Name', section = nil, key = 'name' },
        { title = 'Cost', section = 'Unit Information', key = 'Cost' },
        { title = 'Weight', section = 'Unit Information', key = 'Weight' },
        { title = 'Required Tech Level', section = 'Unit Information', key = 'Required Tech Level' },
        { title = 'Other Requirements', section = 'Unit Information', key = 'Other Requirements' },
        { title = 'Max Energy Level', section = 'Properties', key = 'Max Energy Level' },
        { title = 'Recharge Rate', section = 'Properties', key = 'Recharge Rate' },
        { title = 'Defensive Merit', section = 'Properties', key = 'Defensive Merit' },
    }
    
    return helper.generateTable(data, 'Reactor', cols, 'Could not load data module. Check Module:Reactors/data or Module:Reactors_data exists.')
end

function p.testData(frame)
    local data = DATA or helper.loadData('Module:Reactors/data', 'Module:Reactors_data')
    return helper.testData(data, 'Module:Reactors/data')
end

return p